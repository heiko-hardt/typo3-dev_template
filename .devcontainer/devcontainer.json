// Reference: https://containers.dev/implementors/json_reference/
// Guide: https://containers.dev/guide/dockerfile#docker-compose
{
	// https://containers.dev/implementors/json_reference/#general-properties
	"name": "T3Ext: Common development template",
	"containerEnv": {
		"SHELL": "/bin/zsh"
	},
	"overrideCommand": false,
	"remoteUser": "developer",
	"shutdownAction": "stopCompose",
	"customizations": {
		"vscode": {
			"extensions": [
				"bmewburn.vscode-intelephense-client",
				"cweijan.vscode-mysql-client2",
				"DotJoshJohnson.xml",
				"esbenp.prettier-vscode",
				"ms-vscode.makefile-tools",
				"vector-of-bool.gitflow",
				"xdebug.php-debug"
			]
		}
	},
	// Docker Compose specific properties
	// https://containers.dev/implementors/json_reference/#compose-specific
	"dockerComposeFile": "../.docker/compose.yaml",
	"service": "web",
	"workspaceFolder": "/workspaces/${localWorkspaceFolderBasename}",
	// Lifecycle scripts
	// https://containers.dev/implementors/json_reference/#lifecycle-scripts
	"postCreateCommand": {
		"www": "sudo rm -rf /var/www/html && sudo chown -R developer:developer /var/www && ln -s /workspaces/${localWorkspaceFolderBasename} /var/www/html",
		"zsh": "curl -fsSL https://raw.githubusercontent.com/ohmyzsh/ohmyzsh/master/tools/install.sh | zsh || true"
	}
}